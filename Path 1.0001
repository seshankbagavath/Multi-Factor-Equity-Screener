\"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.4835202031207787,\n        \"min\": -0.49818,\n        \"max\": 1.9540999999999997,\n        \"num_unique_values\": 49,\n        \"samples\": [\n          -0.043,\n          -0.419,\n          -0.085\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"momentum_raw\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.7875490796025474,\n        \"min\": -0.3642134912927508,\n        \"max\": 4.6214421455826376,\n        \"num_unique_values\": 50,\n        \"samples\": [\n          -0.08550857505183185,\n          0.23555756702287223,\n          -0.07662676268455615\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"volatility_raw\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.12313933858463663,\n        \"min\": 0.16740902753481146,\n        \"max\": 0.7521987894255648,\n        \"num_unique_values\": 50,\n        \"samples\": [\n          0.2404837830639154,\n          0.23061058540061077,\n          0.4019407545079805\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"momentum\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.7875490796025474,\n        \"min\": -0.3642134912927508,\n        \"max\": 4.6214421455826376,\n        \"num_unique_values\": 50,\n        \"samples\": [\n          -0.08550857505183185,\n          0.23555756702287223,\n          -0.07662676268455615\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"inv_volatility\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.12313933858463663,\n        \"min\": -0.7521987894255648,\n        \"max\": -0.16740902753481146,\n        \"num_unique_values\": 50,\n        \"samples\": [\n          -0.2404837830639154,\n          -0.23061058540061077,\n          -0.4019407545079805\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"
