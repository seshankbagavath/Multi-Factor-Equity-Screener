      "source": [
        "# ════════════════════════════════════════════════════════════════════════\n",
        "# CELL 2 — CONFIGURATION\n",
        "# ════════════════════════════════════════════════════════════════════════\n",
        "# Central place for all tunable parameters: universe, factor weights,\n",
        "# lookback windows, and cleaning thresholds. Edit here, not in the logic.\n",
        "\n",
        "class Config:\n",
        "    # --- Universe -------------------------------------------------------\n",
        "    # A compact, liquid sample. Swap for the full S&P 500 in production.\n",
        "    UNIVERSE = [\n",
        "        \"AAPL\", \"MSFT\", \"GOOGL\", \"AMZN\", \"META\", \"NVDA\", \"TSLA\", \"JPM\",\n",
        "        \"V\", \"JNJ\", \"WMT\", \"PG\", \"MA\", \"HD\", \"CVX\", \"ABBV\", \"PEP\", \"KO\",\n",
        "        \"COST\", \"MRK\", \"ADBE\", \"CSCO\", \"CRM\", \"MCD\", \"NKE\", \"INTC\", \"AMD\",\n",
        "        \"TXN\", \"QCOM\", \"ORCL\", \"IBM\", \"GE\", \"CAT\", \"BA\", \"GS\", \"MS\", \"XOM\",\n",
        "        \"PFE\", \"T\", \"VZ\", \"DIS\", \"NFLX\", \"PYPL\", \"SBUX\", \"LOW\", \"UNH\",\n",
        "        \"HON\", \"UPS\", \"DE\", \"LMT\",\n",
        "    ]\n",
        "\n",
        "    # --- Price lookbacks (calendar) ------------------------------------\n",
        "    PRICE_PERIOD = \"2y\"          # how much price history to pull\n",
        "    MOMENTUM_LOOKBACK = 252      # ~12 months of trading days\n",
        "    MOMENTUM_SKIP = 21           # skip most-recent month (12-1 momentum)\n",
        "    VOL_LOOKBACK = 252           # realized-vol window\n",
        "\n",
        "    # --- Factor weights (must cover the five families) ------------------\n",
        "    # Sum is normalized automatically; relative magnitude is what matters.\n",
        "    FACTOR_WEIGHTS = {\n",
        "        \"value\":         0.25,\n",
        "        \"profitability\": 0.25,\n",
        "        \"momentum\":      0.20,\n",
        "        \"volatility\":    0.15,   # low-vol tilt (inverted internally)\n",
        "        \"growth\":        0.15,\n",
        "    }\n",
        "\n",
        "    # --- Cleaning -------------------------------------------------------\n",
        "    WINSOR_LIMITS = (0.01, 0.99)  # clip metrics at 1st / 99th percentile\n",
        "    MIN_FACTOR_COVERAGE = 0.50    # drop a stock if >50% of factors missing\n",
        "\n",
        "    # --- Optional API enrichment ---------------------------------------\n",
        "    FMP_API_KEY = \"\"              # paste a free key to enable FMP fallback\n",
        "    SEC_USER_AGENT = \"screener-project contact@example.com\"  # EDGAR requires this\n",
        "\n",
        "    # --- Caching --------------------------------------------------------\n",
        "    CACHE_DIR = \"data/raw\"\n",
        "\n",
        "cfg = Config()\n",
        "os.makedirs(cfg.CACHE_DIR, exist_ok=True)\n",
        "os.makedirs(\"data/processed\", exist_ok=True)\n",
        "print(f\"Configured {len(cfg.UNIVERSE)} tickers across \"\n",
        "      f\"{len(cfg.FACTOR_WEIGHTS)} factor families.\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "8M0O-6seyegx",
        "outputId": "a79e7457-08a8-423f-a1a0-b4595ad4717c"
      },
      "execution_count": null,
